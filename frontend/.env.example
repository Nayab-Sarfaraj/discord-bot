# Local dev: leave as /api — Vite's dev proxy (vite.config.js) forwards it
# to localhost:3000. Deployed (Vercel/Netlify/etc, no such proxy exists):
# set this to the full backend URL, e.g.
# VITE_API_BASE_URL=https://your-backend.onrender.com/api
VITE_API_BASE_URL=/api

# Discord application (client) ID — public by design, safe to expose;
# it's the same ID that appears in the bot's own invite link.
VITE_DISCORD_APPLICATION_ID=

# This app's own public URL, used as the OAuth redirect target after
# adding the bot to a server. Falls back to window.location.origin if unset.
VITE_FRONTEND_URL=
