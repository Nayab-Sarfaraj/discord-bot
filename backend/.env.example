# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Merges the BullMQ worker into this same process — set by `npm start`
# automatically (Render's free tier has no Background Worker option).
# Leave unset for local dev; use `npm run dev` + `npm run worker` as two
# separate processes instead, matching the original architecture.
RUN_WORKER_IN_PROCESS=

# MongoDB
MONGODB_URI=mongodb://localhost:27017/discord-bot

# Redis / BullMQ (Upstash)
REDIS_URL=redis://localhost:6379

# Discord
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=

# Slack
SLACK_WEBHOOK_URL=

# Auth
JWT_SECRET=

# AI (optional) — https://console.groq.com, free tier, no card
GROQ_API_KEY=
